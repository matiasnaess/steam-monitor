# Steam Web API key (get one at https://steamcommunity.com/dev/apikey)
STEAM_API_KEY=your_api_key_here

# Server configuration
PORT=3300
HOST=0.0.0.0

# Monitoring intervals (in milliseconds)
SERVICE_CHECK_INTERVAL=30000
CM_CHECK_INTERVAL=300000
PLAYER_COUNT_INTERVAL=60000
GAME_STATUS_INTERVAL=60000

# CM Discovery
CM_DISCOVERY_INTERVAL=600000
CM_MAX_CELL_ID=220

# History retention (in hours)
HISTORY_RETENTION_HOURS=48

# Log level (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
